# Restaurant-App Umgebungsvariablen

# Server
PORT=3000
NODE_ENV=production

# CORS - Komma-getrennte Liste erlaubter Origins
ALLOWED_ORIGINS=https://desktop-lk7svi7.tailbc2e10.ts.net:8443,http://localhost:5005,http://localhost:3000

# Datenbank
DB_PATH=/app/data/seeblick.db

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Session (für zukünftige Auth)
SESSION_SECRET=your-secret-key-here-change-in-production

# Tailscale
TAILSCALE_URL=https://desktop-lk7svi7.tailbc2e10.ts.net:8443
