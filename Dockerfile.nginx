FROM nginx:alpine

# Install OpenSSL für SSL Zertifikate
RUN apk add --no-cache openssl

# SSL Verzeichnis erstellen
RUN mkdir -p /etc/nginx/ssl

# Kopiere Entrypoint Script
COPY nginx-ssl.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/nginx-ssl.sh

# Kopiere Nginx Konfiguration
COPY nginx-ssl.conf /etc/nginx/conf.d/default.conf

# Ports
EXPOSE 80 443

# Start mit SSL Setup
CMD ["/usr/local/bin/nginx-ssl.sh"]
